# ══════════════════════════════════════════════════════════════════════════════
# AuraScript — Test Environment Variables
#
# Safe, non-secret values used by the automated test suite.
# This file IS committed to git — it must contain NO real secrets.
#
# pytest loads this via: load_dotenv(".env.test") in tests/conftest.py
# ══════════════════════════════════════════════════════════════════════════════

# ── Identity ──────────────────────────────────────────────────────────────────
APP_NAME=AuraScript-Test
APP_VERSION=1.0.0
ENVIRONMENT=development

# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8080
PRIMARY_DOMAIN=http://localhost:8080
SECONDARY_DOMAIN=http://localhost:8081

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Google Vertex AI ──────────────────────────────────────────────────────────
# Mocked in tests — these values are never sent to Google.
GOOGLE_CLOUD_PROJECT=test-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/tmp/test-service-account.json
VERTEX_AI_MODEL_TRANSCRIBE=gemini-2.0-flash
VERTEX_AI_MODEL_STITCH=gemini-2.0-flash
VERTEX_AI_MODEL_QUALITY=gemini-2.0-flash

# ── Security ──────────────────────────────────────────────────────────────────
# Fake API keys used exclusively in unit tests. NOT valid against any real API.
VALID_API_KEYS=test-api-key-aaaa1111,test-api-key-bbbb2222
API_KEY_HEADER=X-API-Key
# Fake webhook secret — safe to commit because it signs no real payloads.
WEBHOOK_SECRET=test-webhook-secret-0000000000000000000000000000000000000000000000
MAX_REQUESTS_PER_MINUTE=60
MAX_REQUESTS_PER_DAY=10000

# ── File Handling ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_BYTES=10485760
UPLOAD_DIR=/tmp/aurascript-test/uploads
CHUNKS_DIR=/tmp/aurascript-test/chunks
ALLOWED_AUDIO_MIME_TYPES=audio/mpeg,audio/wav,audio/mp4,audio/ogg,audio/webm,audio/flac,audio/x-m4a,audio/aac

# ── Processing ────────────────────────────────────────────────────────────────
CHUNK_DURATION_SECONDS=30
MAX_CONCURRENT_GEMINI_CALLS=2
MAX_AUDIO_DURATION_SECONDS=300
QUALITY_SCORE_THRESHOLD=0.6
LOW_CONFIDENCE_THRESHOLD=0.4
MAX_QUALITY_RETRIES=1

# ── Jobs ──────────────────────────────────────────────────────────────────────
JOB_TTL_SECONDS=60
MAX_CONCURRENT_JOBS=5

# ── WebSocket ─────────────────────────────────────────────────────────────────
WS_PING_INTERVAL_SECONDS=25
WS_PING_TIMEOUT_SECONDS=10
WS_MAX_RECONNECT_HISTORY=100

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=console
