# ══════════════════════════════════════════════════════════════════════════════
# AuraScript — Environment Variable Reference
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. Only .env.example and .env.test are committed.
#
# To generate a secure random secret:   openssl rand -hex 32
# ══════════════════════════════════════════════════════════════════════════════


# ── Identity ──────────────────────────────────────────────────────────────────

# Application display name (used in logs and API responses).
APP_NAME=AuraScript

# Semantic version string.
APP_VERSION=1.0.0

# Runtime environment. Controls log format, feature flags, and URL generation.
# Allowed values: development | staging | production
ENVIRONMENT=development


# ── Server ────────────────────────────────────────────────────────────────────

# Interface the Uvicorn server binds to. Use 0.0.0.0 to accept all interfaces.
HOST=0.0.0.0

# Port Uvicorn listens on. Nginx proxies 443 → this port.
PORT=8080

# Primary public domain. Used to construct absolute URLs in API responses.
PRIMARY_DOMAIN=https://www.aurascript.au

# Secondary domain. Nginx redirects this to PRIMARY_DOMAIN.
SECONDARY_DOMAIN=https://www.aurascript.store


# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of origins allowed to call the API from a browser.
# Add your Lovable app origin here once it is deployed.
# Example: https://www.aurascript.au,https://yourapp.lovable.app
ALLOWED_ORIGINS=https://www.aurascript.au,https://www.aurascript.store,http://localhost:3000,http://localhost:5173


# ── Google Vertex AI ──────────────────────────────────────────────────────────

# GCP project ID. Find it in the GCP console under "Project info".
# Example: my-gcp-project-123456
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Vertex AI API region. Must support Gemini 2.0 Flash.
# Recommended: us-central1
GOOGLE_CLOUD_LOCATION=us-central1

# Absolute path to your GCP service account JSON key file.
# Create via: GCP Console → IAM → Service Accounts → Create Key → JSON
# Required roles on the service account: roles/aiplatform.user
# Example: /opt/aurascript/secrets/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Gemini model used for per-chunk transcription.
VERTEX_AI_MODEL_TRANSCRIBE=gemini-2.0-flash

# Gemini model used for final transcript stitching.
VERTEX_AI_MODEL_STITCH=gemini-2.0-flash

# Gemini model used for quality scoring.
VERTEX_AI_MODEL_QUALITY=gemini-2.0-flash


# ── Security ──────────────────────────────────────────────────────────────────

# REQUIRED — Comma-separated list of valid API keys.
# Each client receives one key. Rotate by adding the new key, deploying,
# then removing the old key and deploying again (zero-downtime rotation).
# Generate a key: openssl rand -hex 32
VALID_API_KEYS=replace_with_your_generated_api_key_1,replace_with_your_generated_api_key_2

# HTTP header name the client must send the API key in.
API_KEY_HEADER=X-API-Key

# REQUIRED — HMAC-SHA256 signing key for outbound webhook payloads.
# The receiving server uses this to verify webhook authenticity.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=replace_with_openssl_rand_hex_32_output

# Maximum number of API requests per minute per API key (burst protection).
MAX_REQUESTS_PER_MINUTE=10

# Maximum number of API requests per day per API key (cost control).
MAX_REQUESTS_PER_DAY=200


# ── File Handling ─────────────────────────────────────────────────────────────

# Maximum accepted upload size in bytes. Default is 700 MB.
MAX_UPLOAD_SIZE_BYTES=734003200

# Directory where raw audio uploads are temporarily stored.
# Must be writable by the process user. Created automatically on startup.
UPLOAD_DIR=/tmp/aurascript/uploads

# Directory where audio chunks are temporarily stored during processing.
# Must be writable by the process user. Created automatically on startup.
CHUNKS_DIR=/tmp/aurascript/chunks

# Comma-separated MIME types accepted at upload time.
ALLOWED_AUDIO_MIME_TYPES=audio/mpeg,audio/wav,audio/mp4,audio/ogg,audio/webm,audio/flac,audio/x-m4a,audio/aac


# ── Processing ────────────────────────────────────────────────────────────────

# Duration in seconds of each audio chunk sent to Gemini. 180 = 3 minutes.
CHUNK_DURATION_SECONDS=180

# asyncio.Semaphore cap on concurrent Gemini API calls (cost + rate-limit guard).
MAX_CONCURRENT_GEMINI_CALLS=5

# Hard limit on audio duration. Files longer than this are rejected at upload.
MAX_AUDIO_DURATION_SECONDS=7200

# Minimum quality score [0.0–1.0] before a chunk is retried.
QUALITY_SCORE_THRESHOLD=0.6

# Quality scores below this threshold are flagged as low-confidence in output.
LOW_CONFIDENCE_THRESHOLD=0.4

# How many times a low-quality chunk is retried before flagging and continuing.
MAX_QUALITY_RETRIES=1


# ── Jobs ──────────────────────────────────────────────────────────────────────

# Seconds after creation before a job record is eligible for auto-cleanup.
JOB_TTL_SECONDS=3600

# Maximum number of jobs that can be in PROCESSING state simultaneously.
MAX_CONCURRENT_JOBS=10


# ── WebSocket ─────────────────────────────────────────────────────────────────

# Interval in seconds between server-sent WebSocket pings.
WS_PING_INTERVAL_SECONDS=25

# Seconds to wait for a pong before closing a dead WebSocket connection.
WS_PING_TIMEOUT_SECONDS=10

# Number of past events cached per job for clients that reconnect mid-job.
WS_MAX_RECONNECT_HISTORY=100


# ── Observability ─────────────────────────────────────────────────────────────

# Python logging level. Use DEBUG locally, INFO or WARNING in production.
# Allowed: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log output format. Use "json" in production for log aggregators (e.g. Loki).
# Use "console" for local development readability.
# Allowed: json | console
LOG_FORMAT=json
